# FlowerPower Configuration

# Logging
FP_LOG_LEVEL=INFO

# Web Scraping specific settings
SCRAPER_USER_AGENT=FlowerPower News Scraper 1.0
MAX_CONCURRENT_REQUESTS=5
REQUEST_DELAY=1.0
SCRAPER_TIMEOUT=30
MAX_RETRIES=3

# Content processing
MIN_CONTENT_LENGTH=50
MAX_CONTENT_LENGTH=10000
EXTRACT_KEYWORDS=true
SENTIMENT_ANALYSIS=true
LANGUAGE_DETECTION=true

# Data storage
OUTPUT_FORMAT=json
INCLUDE_METADATA=true
DEDUPLICATION=true

# Scraping environment
ENVIRONMENT=development
